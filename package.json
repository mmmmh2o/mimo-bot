{
  "name": "mimo-bot",
  "version": "0.1.0",
  "description": "网页特化版 AI 自动化工具 — 把 AI 变成你的员工",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite --config renderer/vite.config.js",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build:renderer && electron-builder",
    "build:renderer": "vite build --config renderer/vite.config.js",
    "build:linux": "npm run build:renderer && electron-builder --linux",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "lint": "eslint .",
    "test": "node --test core/__tests__/**/*.test.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "electron-log": "^5.0.0",
    "node-cron": "^3.0.3",
    "playwright": "^1.45.0",
    "simple-git": "^3.25.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue-flow/core": "^1.40.0",
    "concurrently": "^8.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "element-plus": "^2.8.0",
    "eslint": "^9.0.0",
    "pinia": "^2.1.0",
    "vite": "^5.4.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.mimo.bot",
    "productName": "MiMo Bot",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "core/**/*",
      "renderer/dist/**/*",
      "data/**/*",
      "package.json"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
